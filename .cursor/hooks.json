{
  "version": 1,
  "hooks": {
    "afterShellExecution": [
      {
        "command": ".cursor/hooks/refresh-indexes.sh",
        "matcher": "git\\s+merge|gh\\s+pr\\s+merge|git\\s+pull|ccc\\s+init",
        "timeout": 180
      }
    ],
    "beforeAgentMessage": [
      {
        "command": "bash .agents/hooks/cursor-hook.sh UserPromptSubmit"
      }
    ]
  }
}
