{
  "$schema": "https://app.kilo.ai/config.json",
  "model": "kilo/kilo-auto/free",
  "mcp": {
    "context7-http": { 
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.context7.com/sse"
    },
    "deepwiki-http": {
      "enabled": true, 
      "type": "remote",
      "url": "https://mcp.deepwiki.com/sse"
    },
    "exa-http": { 
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.exa.ai/sse"
    },
    "engram": {
      "command": [
        "engram",
        "mcp",
        "--tools=agent"
      ],
      "enabled": true,
      "type": "local"
    },
    "ccc": {
      "enabled": true,
      "type": "local",
      "command": [
        "ccc",
        "mcp"
      ]
    },
    "gitnexus": {
      "enabled": true,
      "type": "local",  
      "command": [
        "npx",
        "-y",
        "gitnexus@1.3.11",
        "mcp"
      ]
    },
    "trivy": {    
      "enabled": true,
      "type": "local", 
      "command": [
        "trivy",
        "mcp"
      ]
    }
  },
  "permission": {
    "bash": {
      "*": "allow",
      "git commit *": "ask",
      "git push": "ask",
      "git push *": "ask",
      "git push --force *": "ask",
      "git rebase *": "ask",
      "git reset --hard *": "ask"
    },
    "read": {
      "*": "allow",
      "**/.env": "deny",
      "**/.env.*": "deny",
      "**/credentials.json": "deny",
      "**/secrets/**": "deny",
      "*.env": "deny",
      "*.env.*": "deny"
    }
  }
}
